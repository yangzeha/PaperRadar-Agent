LLM_PROVIDER=mock
LLM_MODEL_ID=
LLM_API_KEY=
LLM_BASE_URL=

# Optional: LangGraph Studio / LangSmith traces
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=paper-radar-agent

# Gemini legacy path
GOOGLE_API_KEY=your_google_api_key_here
PRIMARY_MODEL=gemini-2.5-flash
FALLBACK_MODEL=gemini-2.0-flash
TERTIARY_MODEL=gemini-2.0-flash-lite

# DeepSeek OpenAI-compatible path
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qwen/DashScope OpenAI-compatible path
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_MODEL_SEQUENCE=qwen-plus,qwen-turbo,qwen-flash,qwen3.5-flash,qwen3.5-plus,qwen-max

# Optional: IEEE Xplore Metadata API
IEEE_API_KEY=

CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=scholar_papers
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
MAX_PAPERS=10
TOP_K_RESULTS=10
